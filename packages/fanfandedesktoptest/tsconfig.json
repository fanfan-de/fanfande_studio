{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "vite/client", "vitest/globals"],
    "noEmit": true
  },
  "include": ["electron.vite.config.ts", "src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "vitest.config.ts"]
}
