graph LR
    %% 事件驱动架构概览
    subgraph "事件驱动架构概览"
        subgraph Producers["事件生产者"]
            P1[SessionProcessor]
            P2[工具执行器]
            P3[权限系统]
            P4[Server API]
        end
        
        subgraph EventBusCenter["事件总线<br/>src/bus/"]
            EB[EventBus<br/>发布-订阅模式]
        end
        
        subgraph Consumers["事件消费者"]
            C1[CLI 客户端]
            C2[TUI 界面]
            C3[Web 客户端]
            C4[日志系统]
            C5[状态跟踪器]
        end
        
        P1 -->|发布事件| EB
        P2 -->|发布事件| EB
        P3 -->|发布事件| EB
        P4 -->|发布事件| EB
        
        EB -->|事件流| C1
        EB -->|事件流| C2
        EB -->|事件流| C3
        EB -->|事件流| C4
        EB -->|事件流| C5
    end
    
    classDef producer fill:#e1f5fe,stroke:#01579b
    classDef bus fill:#f3e5f5,stroke:#4a148c
    classDef consumer fill:#e8f5e8,stroke:#1b5e20
    
    class P1,P2,P3,P4 producer
    class EB bus
    class C1,C2,C3,C4,C5 consumer