{
  "expo": {
    "name": "Anybox Mobile",
    "slug": "anybox-mobile",
    "scheme": "anybox-mobile",
    "version": "0.2.3",
    "icon": "./assets/icon.png",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1420"
    },
    "newArchEnabled": false,
    "android": {
      "package": "studio.fanfande.anybox.mobile",
      "versionCode": 5,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1420"
      },
      "permissions": [
        "INTERNET",
        "CAMERA"
      ]
    },
    "ios": {
      "bundleIdentifier": "studio.fanfande.anybox.mobile",
      "buildNumber": "5",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Anybox Mobile to scan desktop pairing QR codes.",
        "NSLocalNetworkUsageDescription": "Allow Anybox Mobile to connect to your desktop bridge on the local network.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Anybox Mobile to scan desktop pairing QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "anyboxMobileReleaseUrl": "",
      "anyboxMobileGitHubRepository": "fanfan-de/fanfande_studio",
      "anyboxMobileGitHubReleaseTagPrefix": "mobile-v",
      "anyboxMobileGitHubApkAssetName": "anybox-mobile.apk",
      "anyboxMobileGitHubManifestAssetName": "anybox-mobile-release.json",
      "anyboxRelayUrl": "https://anybox.com.cn"
    }
  }
}
