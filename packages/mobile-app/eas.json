{
  "cli": {
    "appVersionSource": "local",
    "version": ">= 20.0.0"
  },
  "build": {
    "development": {
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal"
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true
    }
  }
}
