{
  "name": "anybox-mobile-app",
  "version": "0.2.0",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "autolinking": {
      "android": {
        "legacy_shallowReactNativeLinking": true,
        "exclude": [
          "@react-native-masked-view/masked-view",
          "react-native-drawer-layout",
          "react-native-gesture-handler",
          "react-native-reanimated",
          "react-native-worklets"
        ]
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "android:dev": "expo run:android",
    "android:setup": "node ./scripts/android-toolchain-windows.mjs",
    "android:build:debug": "node ./scripts/build-android-debug.mjs",
    "android:install:debug": "node ./scripts/install-android-debug.mjs",
    "android:smoke:debug": "node ./scripts/android-launch-smoke.mjs",
    "android:smoke:bridge": "node ./scripts/android-real-bridge-smoke.mjs",
    "android:smoke:pairing": "node ./scripts/android-pairing-smoke.mjs",
    "android:delivery-check": "node ./scripts/android-delivery-check.mjs",
    "android:handoff-check": "node ./scripts/android-handoff-check.mjs",
    "build:android:apk": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "update:preview": "eas update --channel preview --environment preview",
    "update:production": "eas update --channel production --environment production",
    "release:github:prepare": "node ./scripts/prepare-github-mobile-release.mjs",
    "doctor": "node ./scripts/mobile-doctor.mjs",
    "smoke": "node ./scripts/mobile-smoke.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "56.0.13",
    "expo": "56.0.8",
    "expo-camera": "~56.0.7",
    "expo-constants": "56.0.16",
    "expo-router": "56.2.8",
    "expo-secure-store": "56.0.4",
    "expo-status-bar": "56.0.4",
    "expo-updates": "~56.0.17",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-sse": "1.2.1"
  },
  "devDependencies": {
    "@types/react": "19.2.16",
    "babel-preset-expo": "56.0.14",
    "eas-cli": "^20.0.0",
    "typescript": "6.0.3"
  }
}
