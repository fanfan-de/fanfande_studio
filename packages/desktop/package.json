{
  "name": "anybox-desktop-agent",
  "version": "0.1.11",
  "private": true,
  "description": "Anybox desktop AI agent workspace",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:debug": "node ./scripts/dev.mjs --agent-log-level=DEBUG",
    "dev:info": "node ./scripts/dev.mjs --agent-log-level=INFO",
    "dev:warn": "node ./scripts/dev.mjs --agent-log-level=WARN",
    "dev:error": "node ./scripts/dev.mjs --agent-log-level=ERROR",
    "appearance:promote": "node ./scripts/promote-appearance-theme.mjs",
    "build:agent-runtime": "node ./scripts/prepare-agent-runtime.mjs",
    "build:monitor": "corepack pnpm --filter anybox-monitor build",
    "build": "corepack pnpm run build:agent-runtime && corepack pnpm run build:monitor && electron-vite build",
    "icons:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/generate-app-icons.ps1",
    "verify:agent-runtime": "node ./scripts/verify-agent-runtime.mjs",
    "dist": "corepack pnpm run build && corepack pnpm run verify:agent-runtime && corepack pnpm run icons:generate && node ./node_modules/electron-builder/cli.js --publish never",
    "dist:publish": "corepack pnpm run build && corepack pnpm run verify:agent-runtime && corepack pnpm run icons:generate && node ./node_modules/electron-builder/cli.js --publish always",
    "dist:dir": "corepack pnpm run build && corepack pnpm run verify:agent-runtime && corepack pnpm run icons:generate && node ./node_modules/electron-builder/cli.js --dir --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@anybox/platform": "workspace:*",
    "@anybox/shared": "workspace:*",
    "@lexical/history": "^0.43.0",
    "@lexical/plain-text": "^0.43.0",
    "@lexical/react": "^0.43.0",
    "@lexical/utils": "^0.43.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dockview-react": "^6.2.2",
    "dompurify": "^3.4.5",
    "electron-updater": "^6.8.3",
    "lexical": "^0.43.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.8"
  }
}
