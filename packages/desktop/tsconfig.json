{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "vite/client", "vitest/globals"],
    "noEmit": true,
    "paths": {
      "@anybox/shared": ["../shared/src/index.ts"],
      "@anybox/shared/*": ["../shared/src/*"],
      "@anybox/platform": ["../platform/src/index.ts"],
      "zod": ["../anyboxagent/node_modules/zod"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "vitest.config.ts",
    "../shared/src/**/*.ts",
    "../platform/src/**/*.ts"
  ],
  "exclude": ["../shared/src/**/*.test.ts", "../platform/src/**/*.test.ts"]
}
