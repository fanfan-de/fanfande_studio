{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Fanfande Desktop (Electron)",
      "runtimeExecutable": "corepack",
      "runtimeArgs": ["pnpm", "--filter", "fanfande-desktop-agent", "dev"],
      "port": 5173
    },
    {
      "name": "Fanfande Agent Server",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "src/server/start.ts"],
      "cwd": "packages/fanfandeagent",
      "port": 4096
    }
  ]
}
