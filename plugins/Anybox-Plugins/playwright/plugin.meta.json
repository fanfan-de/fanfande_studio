{
  "id": "playwright",
  "name": "playwright",
  "version": "1.0.0",
  "description": "Drive a local browser through MCP for page inspection, screenshots, and interaction testing.",
  "author": {
    "name": "Microsoft Playwright",
    "url": "https://github.com/microsoft/playwright-mcp"
  },
  "homepage": "https://github.com/microsoft/playwright-mcp",
  "interface": {
    "displayName": "Playwright Browser",
    "shortDescription": "Drive a local browser through MCP.",
    "developerName": "Microsoft Playwright",
    "category": "Browser",
    "capabilities": [
      "Interactive",
      "Read",
      "Write"
    ],
    "logo": "PW",
    "screenshots": [],
    "longDescription": "Drive a local browser through MCP for page inspection, screenshots, and interaction testing.",
    "iconUrl": "data:image/svg+xml;base64,",
    "brandColor": "#2EAD33"
  },
  "mcpServers": [
    {
      "name": "Playwright Browser",
      "risk": "medium",
      "permissions": [
        "Starts a local browser process",
        "Can navigate to network URLs",
        "Can click and type on pages"
      ],
      "tools": [
        {
          "name": "browser_navigate",
          "title": "Navigate",
          "description": "Open a URL in the controlled browser.",
          "readOnly": false
        },
        {
          "name": "browser_snapshot",
          "title": "Snapshot",
          "description": "Read the current page accessibility snapshot.",
          "readOnly": true
        },
        {
          "name": "browser_click",
          "title": "Click",
          "description": "Click a visible element on the page.",
          "readOnly": false
        }
      ],
      "runtime": {
        "transport": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@playwright/mcp@latest"
        ],
        "timeoutMs": 30000
      },
      "installReview": [
        "The plugin launches a browser automation server as an external process.",
        "Tool calls can interact with pages after the existing permission layer approves them."
      ]
    }
  ],
  "skillPreviews": [],
  "package": {
    "type": "zip",
    "url": "https://raw.githubusercontent.com/fanfan-de/fanfande_studio/master/plugins/Anybox-Plugins/playwright/playwright-1.0.0.zip",
    "sha256": "80a73e1490830f7d5dd1b052a9240a52cd1786c1e58bdd0b389062e2316e8f27",
    "size": 1415
  }
}
