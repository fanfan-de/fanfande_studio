{
  "id": "smtp-email",
  "name": "smtp-email",
  "version": "0.1.0",
  "description": "通过用户配置的 SMTP 邮箱发送邮件。",
  "author": {
    "name": "Anybox"
  },
  "homepage": "https://en.wikipedia.org/wiki/Simple_Mail_Transfer_Protocol",
  "repository": "https://github.com/fanfan-de/anybox/tree/master/plugins/Anybox-Plugins/smtp-email",
  "license": "MIT",
  "keywords": [
    "邮箱",
    "smtp",
    "邮件",
    "自动化"
  ],
  "interface": {
    "displayName": "SMTP 邮箱",
    "shortDescription": "通过 SMTP 发送邮件",
    "longDescription": "连接支持 SMTP 的邮箱或授权码，让 Agent 通过配置的账号发送纯文本或 HTML 邮件。",
    "developerName": "Anybox",
    "category": "Automation",
    "capabilities": [
      "邮箱",
      "SMTP",
      "写入"
    ],
    "websiteURL": "https://en.wikipedia.org/wiki/Simple_Mail_Transfer_Protocol",
    "defaultPrompt": [
      "通过我配置的 SMTP 邮箱发送邮件"
    ],
    "brandColor": "#2563EB",
    "logo": "SM",
    "screenshots": [],
    "iconUrl": "data:image/svg+xml;base64,"
  },
  "skills": "./skills/",
  "connectors": [
    {
      "id": "smtp",
      "name": "SMTP 邮箱",
      "description": "用于通过已配置 SMTP 服务器发送邮件的本地 MCP 连接器。",
      "risk": "medium",
      "permissions": [
        "将 SMTP 密码或邮箱授权码保存在连接器凭据存储中。",
        "会连接到你配置的 SMTP、SMTPS 或 STARTTLS 邮件服务器。",
        "可以从配置的发件邮箱向用户指定的收件人发送邮件。"
      ],
      "configFields": [
        {
          "key": "SMTP_HOST",
          "label": "SMTP 服务器",
          "type": "text",
          "required": true,
          "placeholder": "smtp.qq.com",
          "description": "邮箱服务商提供的 SMTP 服务器地址，例如 QQ 邮箱填 smtp.qq.com。"
        },
        {
          "key": "SMTP_PORT",
          "label": "SMTP 端口",
          "type": "text",
          "required": false,
          "defaultValue": "587",
          "placeholder": "587",
          "description": "常见端口：587 对应 STARTTLS，465 对应 SSL/TLS，25 仅用于服务商明确允许的普通 SMTP。"
        },
        {
          "key": "SMTP_SECURITY",
          "label": "加密方式",
          "type": "text",
          "required": false,
          "defaultValue": "starttls",
          "placeholder": "starttls",
          "description": "填写 starttls、tls 或 none。大多数邮箱使用 587 + starttls，或 465 + tls。"
        },
        {
          "key": "SMTP_USERNAME",
          "label": "邮箱账号",
          "type": "text",
          "required": true,
          "placeholder": "user@qq.com",
          "description": "SMTP 登录账号，通常填写完整邮箱地址。"
        },
        {
          "key": "SMTP_FROM_EMAIL",
          "label": "发件邮箱",
          "type": "text",
          "required": true,
          "placeholder": "user@qq.com",
          "description": "邮件 From 头和 SMTP 发件信封使用的邮箱地址。"
        },
        {
          "key": "SMTP_FROM_NAME",
          "label": "发件人名称",
          "type": "text",
          "required": false,
          "placeholder": "你的名字",
          "description": "可选，显示在邮件 From 头里的发件人名称。"
        }
      ],
      "credential": {
        "kind": "api_key",
        "key": "SMTP_PASSWORD",
        "label": "SMTP 密码/授权码",
        "type": "password",
        "required": true,
        "secret": true,
        "placeholder": "密码或授权码",
        "description": "SMTP 密码，或邮箱服务商生成的授权码/应用专用密码。"
      },
      "runtime": {
        "transport": "stdio",
        "command": "node",
        "args": [
          "${PLUGIN_ROOT}/connectors/smtp/server.js"
        ],
        "cwd": "${PLUGIN_ROOT}",
        "env": {
          "SMTP_HOST": "${SMTP_HOST}",
          "SMTP_PORT": "${SMTP_PORT}",
          "SMTP_SECURITY": "${SMTP_SECURITY}",
          "SMTP_USERNAME": "${SMTP_USERNAME}",
          "SMTP_PASSWORD": "${SMTP_PASSWORD}",
          "SMTP_FROM_EMAIL": "${SMTP_FROM_EMAIL}",
          "SMTP_FROM_NAME": "${SMTP_FROM_NAME}"
        },
        "timeoutMs": 30000
      },
      "tools": [
        {
          "name": "smtp_email_test_connection",
          "title": "测试 SMTP 连接",
          "description": "验证 SMTP 服务器配置和账号密码，不会发送邮件。",
          "readOnly": true
        },
        {
          "name": "smtp_email_send",
          "title": "发送 SMTP 邮件",
          "description": "通过配置的 SMTP 账号发送纯文本或 HTML 邮件。",
          "readOnly": false,
          "destructive": false
        }
      ],
      "installReview": [
        "需要填写 SMTP 服务器、端口、邮箱账号、发件地址以及密码或授权码。",
        "如果邮箱服务商支持应用专用密码或授权码，建议优先使用授权码。",
        "发送工具会通过已配置账号向外部收件人投递邮件。"
      ]
    }
  ],
  "skillPreviews": [
    {
      "name": "SMTP 邮箱",
      "description": "当用户明确要求发送邮件时，通过用户配置的 SMTP 邮箱发送邮件。",
      "directory": "smtp-email"
    }
  ],
  "package": {
    "type": "zip",
    "url": "https://raw.githubusercontent.com/fanfan-de/anybox/master/plugins/Anybox-Plugins/smtp-email/smtp-email-0.1.0.zip",
    "sha256": "f44b5c92c7fa4b840ce3fff6d2e738c46e22c0beb1dbbdcdaecd739a49cba2ee",
    "size": 7653
  }
}
