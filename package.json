{
  "name": "anybox",
  "version": "0.1.13",
  "private": true,
  "description": "Anybox desktop AI agent workspace",
  "main": "index.js",
  "scripts": {
    "dev": "corepack pnpm --filter anybox-desktop-agent dev",
    "dev:debug": "corepack pnpm --filter anybox-desktop-agent dev:debug",
    "dev:info": "corepack pnpm --filter anybox-desktop-agent dev:info",
    "dev:warn": "corepack pnpm --filter anybox-desktop-agent dev:warn",
    "dev:error": "corepack pnpm --filter anybox-desktop-agent dev:error",
    "build": "corepack pnpm --filter anybox-desktop-agent build",
    "dist": "corepack pnpm --filter anybox-desktop-agent dist",
    "dist:publish": "corepack pnpm --filter anybox-desktop-agent dist:publish",
    "site:build": "corepack pnpm --filter anybox-site build",
    "site:dev": "corepack pnpm --filter anybox-site dev",
    "site:preview": "corepack pnpm --filter anybox-site preview",
    "site:typecheck": "corepack pnpm --filter anybox-site typecheck",
    "monitor:build": "corepack pnpm --filter anybox-monitor build",
    "monitor:dev": "corepack pnpm --filter anybox-monitor dev",
    "monitor:preview": "corepack pnpm --filter anybox-monitor preview",
    "monitor:typecheck": "corepack pnpm --filter anybox-monitor typecheck",
    "mobile:start": "corepack pnpm --filter anybox-mobile-app start",
    "mobile:android": "corepack pnpm --filter anybox-mobile-app android",
    "mobile:android:dev": "corepack pnpm --filter anybox-mobile-app android:dev",
    "mobile:android:setup": "corepack pnpm --filter anybox-mobile-app run android:setup",
    "mobile:android:build:debug": "corepack pnpm --filter anybox-mobile-app run android:build:debug",
    "mobile:android:install:debug": "corepack pnpm --filter anybox-mobile-app run android:install:debug",
    "mobile:android:smoke:debug": "corepack pnpm --filter anybox-mobile-app run android:smoke:debug",
    "mobile:android:smoke:bridge": "corepack pnpm --filter anybox-mobile-app run android:smoke:bridge",
    "mobile:android:smoke:pairing": "corepack pnpm --filter anybox-mobile-app run android:smoke:pairing",
    "mobile:android:delivery-check": "corepack pnpm --filter anybox-mobile-app run android:delivery-check",
    "mobile:android:handoff-check": "corepack pnpm --filter anybox-mobile-app run android:handoff-check",
    "mobile:build:android:apk": "corepack pnpm --filter anybox-mobile-app build:android:apk",
    "mobile:build:android:production": "corepack pnpm --filter anybox-mobile-app build:android:production",
    "mobile:update:preview": "corepack pnpm --filter anybox-mobile-app update:preview",
    "mobile:update:production": "corepack pnpm --filter anybox-mobile-app update:production",
    "mobile:release:github:prepare": "corepack pnpm --filter anybox-mobile-app release:github:prepare",
    "mobile:doctor": "corepack pnpm --filter anybox-mobile-app run doctor",
    "mobile:smoke": "corepack pnpm --filter anybox-mobile-app run smoke",
    "mobile:typecheck": "corepack pnpm --filter anybox-mobile-app typecheck",
    "test": "corepack pnpm --filter anybox-desktop-agent test",
    "typecheck": "corepack pnpm --filter anybox-desktop-agent typecheck",
    "verify:versions": "node ./scripts/verify-product-version.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^39.2.7",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
